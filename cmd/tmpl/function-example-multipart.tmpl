// {{.Description}}
func Example{{.Tag}}Service_{{.Name}}() {
    client, err := {{.PackageName}}.NewClientFromEnv("your apps user agent")
    if err != nil {
        panic(err)
    }

    form := {{.PackageName}}.NewMultipartForm()

    {{if .Response}}
        result, err := client.{{.Tag}}.{{.Name}}({{range .Args -}}{{.Example}},{{end -}} form)
        if err != nil {
            panic(err)
        }

        fmt.Printf("%#v", result)
    {{else}}
    if err := client.{{.Tag}}.{{.Name}}({{range .Args -}}{{.Example}},{{end -}} form); err != nil {
        panic(err)
    }
    {{end}}
}
